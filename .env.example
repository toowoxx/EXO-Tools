# ===========================================================================
# EXO Tools – Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to source control.
# ===========================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
# Generate a strong random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET_KEY=replace-with-a-strong-random-secret-key

# Set to "development" for debug mode (never use in production)
NODE_ENV=production

# ---------------------------------------------------------------------------
# Azure AD App Registration (user authentication + Microsoft Graph API)
# ---------------------------------------------------------------------------
# Application (client) ID from the Azure portal
CLIENT_ID=00000000-0000-0000-0000-000000000000

# Client secret value (from Certificates & secrets in the Azure portal)
CLIENT_SECRET=your-client-secret-here

# Directory (tenant) ID
TENANT_ID=00000000-0000-0000-0000-000000000000

# The redirect URI configured in the app registration.
# IMPORTANT: must end with /callback — e.g. https://<appname>.azurewebsites.net/callback
# Make sure this exact URI is registered in the Azure AD app registration.
# For local dev: http://localhost:5000/callback
# For Azure App Service: https://<appname>.azurewebsites.net/callback
REDIRECT_URI=http://localhost:5000/callback

# ---------------------------------------------------------------------------
# Access Control
# ---------------------------------------------------------------------------
# Object ID of the Entra ID security group whose members may use this app.
# Comment out or leave empty to allow all authenticated users in the tenant.
ACCESS_GROUP_ID=00000000-0000-0000-0000-000000000000

# ---------------------------------------------------------------------------
# Exchange Online App Registration (PowerShell app-only authentication)
# ---------------------------------------------------------------------------
# Application (client) ID of the second app registration used for EXO
EXO_APP_ID=00000000-0000-0000-0000-000000000000

# Absolute path to the PFX certificate file used for EXO app-only auth.
# When running in Docker this maps to /app/certs/exo.pfx by default.
EXO_CERT_PATH=/app/certs/exo.pfx

# Password for the PFX certificate (leave empty if the certificate has no password)
EXO_CERT_PASSWORD=

# Primary domain of your M365 tenant (the *.onmicrosoft.com address)
EXO_ORGANIZATION=yourtenant.onmicrosoft.com

# ---------------------------------------------------------------------------
# PowerShell
# ---------------------------------------------------------------------------
# Path to the PowerShell Core executable.
# Defaults to "pwsh" (must be on PATH).
# Override if pwsh is installed in a non-standard location.
PWSH_PATH=pwsh

# Maximum seconds to wait for the permission-check script before timing out.
# Increase for very large tenants (many mailboxes). Default: 600 (10 minutes)
PS_TIMEOUT=600

# ---------------------------------------------------------------------------
# Port (used by gunicorn / Azure App Service)
# ---------------------------------------------------------------------------
PORT=5000
